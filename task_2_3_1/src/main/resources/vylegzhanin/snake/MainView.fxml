<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="vylegzhanin.snake.controller.GameController">
    <top>
        <HBox alignment="CENTER" spacing="20" style="-fx-padding: 10;">
            <Label fx:id="levelLabel" text="Level: 1" style="-fx-font-size: 16px;" />
            <Label fx:id="scoreLabel" text="Score: 1" style="-fx-font-size: 16px;" />
            <Label fx:id="statusLabel" text="Ready to start" style="-fx-font-size: 16px; -fx-text-fill: blue;" />
            <Button fx:id="actionBtn" text="Start" onAction="#handleAction" focusTraversable="false" />
        </HBox>
    </top>
    <center>
        <Canvas fx:id="canvas" width="450" height="450" />
    </center>
</BorderPane>

